# DrishtiRakshak AI — backend configuration example
#
# Copy this file to `.env` (which is gitignored) for local development:
#     cp .env.example .env
# then set a unique SECRET_KEY. In production, supply these as real
# environment variables via the deployment platform instead of a .env file.
#
# Precedence: real environment variables ALWAYS win over values in .env.
# See docs/ARCHITECTURE.md ("Configuration loading") for the full contract.

# --- REQUIRED ---
# No default. The app fails fast (ImproperlyConfigured) if this is unset.
# Generate one, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-unique-secret-key

# --- OPTIONAL (safe defaults shown) ---
# Enable Django debug mode. Defaults to False (secure by default).
# Set to True ONLY for local development.
DEBUG=True

# Comma-separated hosts Django will serve. Defaults to localhost,127.0.0.1.
# In production set this to your real domain(s), e.g. api.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed to call the API from a browser.
# Defaults to the local Vite dev server origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
